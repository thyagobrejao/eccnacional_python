ENV=development
DEBUG=True

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=eccnacional
AWS_S3_REGION_NAME=us-west-1

# AWS SES (email) - região pode ser diferente do S3
AWS_SES_REGION_NAME=us-east-1
AWS_SES_CONFIGURATION_SET=
DEFAULT_FROM_EMAIL=noreply@eccnacional.com.br
CONTACT_FORM_RECIPIENT_EMAIL=contato@conselhonacional.com.br

DB_NAME=eccnacional
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_SSLMODE=prefer